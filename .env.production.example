# Production environment template.
# Copy to .env on the production host and fill in real values.
# Never commit the actual .env file.

# Public domain or <ip>.nip.io for Caddy auto-HTTPS
DOMAIN=news-analyzer.example.ru

# Mode: real (uses VK API) or mock (synthetic data)
COLLECTOR_MODE=real

# VK
VK_TOKEN=
# Optional: comma-separated pool of tokens to multiply the daily quota
# VK_TOKENS=token1,token2,token3
VK_COMMUNITIES=ria,tassagency,rbc_news,lentaru,meduzaproject,kommersant_ru,breakingmash,rt_russian,kp_ru
VK_POLL_INTERVAL=180

# Telegram (optional, leave blank to keep collector in mock mode)
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=news_collector
TG_CHANNELS=

# Redis (internal docker network)
REDIS_URL=redis://redis:6379/0
STREAM_RAW_VK=raw.vk
STREAM_RAW_TG=raw.tg
STREAM_CLEAN=clean.posts
STREAM_ENRICHED=enriched.posts

# OpenSearch (internal docker network)
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=admin

# Neo4j (internal docker network)
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
# CHANGE THIS to a strong password before deploying
NEO4J_PASS=neopassword123

# NLP: 'lite' (lexicon) or 'full' (RuBERT, ~700MB extra)
NLP_MODE=lite

# API
API_BASE_URL=http://api-gateway:8000

# Dashboard
DASHBOARD_PORT=8501

LOG_LEVEL=INFO
