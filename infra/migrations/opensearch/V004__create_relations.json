{
  "action": "create_index",
  "index": "relations",
  "body": {
    "settings": { "number_of_shards": 1, "number_of_replicas": 0 },
    "mappings": {
      "properties": {
        "post_id":   { "type": "keyword" },
        "head":      { "type": "keyword" },
        "head_type": { "type": "keyword" },
        "tail":      { "type": "keyword" },
        "tail_type": { "type": "keyword" },
        "rel_type":  { "type": "keyword" },
        "weight":    { "type": "float" },
        "sentence":  { "type": "text", "analyzer": "russian" }
      }
    }
  }
}
