{
  "action": "create_index",
  "index": "raw_posts",
  "body": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "analysis": {
        "analyzer": {
          "russian_news": { "type": "russian" }
        }
      }
    },
    "mappings": {
      "properties": {
        "id":          { "type": "keyword" },
        "source":      { "type": "keyword" },
        "text":        { "type": "text", "analyzer": "russian_news" },
        "text_clean":  { "type": "text", "analyzer": "russian_news" },
        "tokens":      { "type": "keyword" },
        "lemmas":      { "type": "keyword" },
        "posted_at":   { "type": "date" },
        "simhash":     { "type": "keyword" },
        "metadata": {
          "properties": {
            "channel": { "type": "keyword" },
            "url":     { "type": "keyword" },
            "likes":   { "type": "integer" },
            "reposts": { "type": "integer" },
            "views":   { "type": "integer" }
          }
        }
      }
    }
  }
}
