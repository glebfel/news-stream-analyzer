{
  "uid": "news-pipeline",
  "title": "News Stream Analyzer — Pipeline",
  "tags": ["news-stream-analyzer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "service_up",
          "legendFormat": "{{service}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Posts collected per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (source) (rate(posts_collected_total[1m]))",
          "legendFormat": "{{source}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Dedup outcome (kept vs duplicate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(posts_dedup_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "NLP processing latency (p50, p95, p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(nlp_processing_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nlp_processing_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nlp_processing_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "NER entities by type (rate/min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (entity_type) (rate(ner_entities_total[1m])) * 60",
          "legendFormat": "{{entity_type}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sentiment label distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (label) (rate(sentiment_predictions_total[5m]))",
          "legendFormat": "{{label}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Wikidata cache hit ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(wikidata_cache_hits_total[5m]) / (rate(wikidata_cache_hits_total[5m]) + rate(wikidata_cache_misses_total[5m]))",
          "legendFormat": "hit ratio",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Graph: flushes/sec & buffer depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(graph_flush_total[1m])",
          "legendFormat": "flush rate",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "graph_buffer_depth",
          "legendFormat": "buffer {{kind}}",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Graph flush size (entities per batch, p50/p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, kind) (rate(graph_flush_size_bucket[5m])))",
          "legendFormat": "p50 {{kind}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(graph_flush_size_bucket[5m])))",
          "legendFormat": "p95 {{kind}}",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ]
}
