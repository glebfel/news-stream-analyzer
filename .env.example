# Mode: mock | real
COLLECTOR_MODE=mock

# VK
# Single service token (legacy):
VK_TOKEN=
# Or comma-separated pool of tokens for round-robin (multiplies daily quota by N):
# VK_TOKENS=token1,token2,token3
VK_COMMUNITIES=ria,tassagency,rbc_news
VK_POLL_INTERVAL=60

# Telegram
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=news_collector
TG_CHANNELS=ria,tass,bbcrussian

# Redis
REDIS_URL=redis://redis:6379/0
STREAM_RAW_VK=raw.vk
STREAM_RAW_TG=raw.tg
STREAM_CLEAN=clean.posts
STREAM_ENRICHED=enriched.posts

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=admin

# Neo4j
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=neopassword123

# NLP
NLP_MODE=lite
HF_HUB_OFFLINE=0
TRANSFORMERS_CACHE=/app/models/cache

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8501
API_BASE_URL=http://api-gateway:8000

LOG_LEVEL=INFO
